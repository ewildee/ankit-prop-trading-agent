# BLUEPRINT §17.5 + §0.1. Copy to .env and fill blanks. Never commit .env.
# `@triplon/config` resolves these names from accounts.config.yaml /
# supervisor.config.yaml `*_env` references.

# --- LLM provider (OpenRouter) ---
OPENROUTER_API_KEY=
# Soft monthly USD cap; alert at 80% of this value.
OPENROUTER_MONTHLY_CAP_USD=

# --- cTrader Open API application credentials (broker socket OAuth) ---
# Single app, used for IC Markets demo today and FTMO challenge demos later.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
# Loopback redirect, e.g. http://127.0.0.1:9210/oauth/callback
CTRADER_REDIRECT_URI=

# --- Broker accounts (per BLUEPRINT §17.1 *_env references) ---
# IC Markets demo (Phase 2 smoke-test target).
BROKER_ACCT_IC_DEMO_1=          # numeric ctidTraderAccountId
BROKER_LOGIN_IC_DEMO_1=         # cTrader account login
BROKER_INITIAL_BALANCE_IC_DEMO_1=

# FTMO 100k 2-step #1 — leave blank until challenge purchased.
BROKER_ACCT_FTMO_1=             # numeric ctidTraderAccountId
BROKER_CREDS_FTMO_1=            # JSON path or kms-ref to encrypted creds
BROKER_INITIAL_BALANCE_FTMO_1=100000

# --- Local secrets encryption (refresh_token.enc, AES-GCM) ---
# 32-byte hex; rotate via `bun run secrets:rotate`. Generate fresh per host.
SECRETS_ENCRYPTION_KEY=

# --- Alerting (optional but recommended) ---
ALERT_WEBHOOK_URL=              # generic webhook (Slack/Discord/etc.)
ALERT_OPERATOR_HANDLE=          # e.g. @etienne, mentioned on critical alerts

# --- Telemetry (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=    # blank → telemetry disabled
OTEL_SERVICE_NAME=ankit-prop    # service-name prefix

# --- Operating mode (BLUEPRINT §1.4) ---
RUNTIME_MODE=dev                # dev | prod
DAILY_SUMMARY_TIME=22:30        # HH:MM Europe/Prague (FTMO server clock)
OPERATOR_TIMEZONE=Europe/Amsterdam
